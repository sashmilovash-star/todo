<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="apple-mobile-web-app-title" content="Дела">
<title>Дела</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f5f5f0;min-height:100vh;padding-bottom:40px}
h1{font-size:22px;font-weight:600;padding:20px 16px 8px;color:#1a1a1a}
.add-row{display:flex;gap:8px;padding:8px 16px 16px;position:sticky;top:0;background:#f5f5f0;z-index:10;border-bottom:1px solid #e8e8e3}
.add-row input{flex:1;padding:10px 14px;border:1px solid #ddd;border-radius:12px;background:#fff;font-size:16px;color:#1a1a1a;outline:none}
.add-row input:focus{border-color:#aaa}
.add-row button{padding:10px 18px;border:none;border-radius:12px;background:#1a1a1a;color:#fff;font-size:16px;cursor:pointer;white-space:nowrap}
.section-label{font-size:12px;color:#999;text-transform:uppercase;letter-spacing:.06em;padding:16px 16px 6px}
.item{display:flex;align-items:center;gap:12px;padding:12px 16px;background:#fff;border-bottom:1px solid #f0f0eb;cursor:pointer;user-select:none}
.item:first-child{border-top-left-radius:12px;border-top-right-radius:12px}
.item:last-child{border-bottom-left-radius:12px;border-bottom-right-radius:12px;border-bottom:none}
.items-wrap{margin:0 12px;border-radius:12px;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.item.done .text{text-decoration:line-through;color:#bbb}
.check{width:22px;height:22px;border:1.5px solid #ccc;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .15s}
.item.done .check{background:#1a1a1a;border-color:#1a1a1a}
.checkmark{display:none;width:12px;height:8px;border-left:2px solid #fff;border-bottom:2px solid #fff;transform:rotate(-45deg) translate(1px,-1px)}
.item.done .checkmark{display:block}
.text{font-size:16px;color:#1a1a1a;flex:1;line-height:1.4}
.del{font-size:20px;color:#ccc;background:none;border:none;cursor:pointer;padding:0 2px;line-height:1;flex-shrink:0}
.done-section{margin-top:8px}
.clear-btn{font-size:13px;color:#bbb;background:none;border:none;cursor:pointer;padding:0 16px 8px;display:block}
.empty{text-align:center;color:#bbb;font-size:15px;padding:32px 16px}
</style>
</head>
<body>
 
<h1>Дела</h1>
 
<div class="add-row">
  <input type="text" id="inp" placeholder="Новая задача..." />
  <button onclick="addTask()">+</button>
</div>
 
<div id="active-section">
  <div class="section-label">Задачи</div>
  <div class="items-wrap" id="active-list"></div>
  <p class="empty" id="empty-msg" style="display:none">Всё сделано 🎉</p>
</div>
 
<div id="done-section" class="done-section" style="display:none">
  <div class="section-label">Выполнено</div>
  <div class="items-wrap" id="done-list"></div>
  <button class="clear-btn" onclick="clearDone()">очистить выполненное</button>
</div>
 
<script>
const INITIAL = [
  "Найти мастера для ванной",
  "Найти мастера для ПММ",
  "Записаться на танцы",
  "Записаться к репродуктологу",
  "Купить шлем Глебу",
  "Спланировать фотосессию",
  "Позвонить свекрови",
  "Подарки Глебу: билет, штаны, футболка",
  "Записать песню для Глеба",
  "Купить билет в Кострому",
  "Форесколор: написать оптовым новые цены",
  "Форесколор: снять видео шлифовки + рилс",
  "Назначить встречи с приятельницами",
  "Выстроить уход за цветами",
  "Убраться дома",
  "Тренировка 30 мин",
  "Одно дело по дому",
  "Работа — хоть что-то"
];
 
let tasks = [];
 
function save() { localStorage.setItem('tasks_v1', JSON.stringify(tasks)); }
function load() {
  try {
    const d = localStorage.getItem('tasks_v1');
    tasks = d ? JSON.parse(d) : INITIAL.map((t, i) => ({id: i, text: t, done: false}));
  } catch(e) {
    tasks = INITIAL.map((t, i) => ({id: i, text: t, done: false}));
  }
}
 
function render() {
  const active = tasks.filter(t => !t.done);
  const done = tasks.filter(t => t.done);
  document.getElementById('active-list').innerHTML = active.map(itemHTML).join('');
  document.getElementById('done-list').innerHTML = done.map(itemHTML).join('');
  document.getElementById('empty-msg').style.display = active.length ? 'none' : 'block';
  document.getElementById('active-list').style.display = active.length ? 'block' : 'none';
  document.getElementById('done-section').style.display = done.length ? 'block' : 'none';
}
 
function itemHTML(t) {
  return `<div class="item${t.done?' done':''}" onclick="toggle(${t.id})">
    <div class="check"><div class="checkmark"></div></div>
    <span class="text">${t.text}</span>
    <button class="del" onclick="event.stopPropagation();del(${t.id})">×</button>
  </div>`;
}
 
function addTask() {
  const inp = document.getElementById('inp');
  const text = inp.value.trim();
  if (!text) return;
  tasks.unshift({id: Date.now(), text, done: false});
  inp.value = '';
  save(); render();
}
 
function toggle(id) {
  const t = tasks.find(t => t.id === id);
  if (t) t.done = !t.done;
  save(); render();
}
 
function del(id) {
  tasks = tasks.filter(t => t.id !== id);
  save(); render();
}
 
function clearDone() {
  tasks = tasks.filter(t => !t.done);
  save(); render();
}
 
document.getElementById('inp').addEventListener('keydown', e => { if (e.key === 'Enter') addTask(); });
load(); render();
</script>
</body>
</html>
 
